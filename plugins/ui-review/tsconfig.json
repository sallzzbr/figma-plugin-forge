{
  "extends": "@create-figma-plugin/tsconfig",
  "compilerOptions": {
    "typeRoots": [
      "node_modules/@figma",
      "node_modules/@types"
    ],
    "jsx": "react",
    "jsxFactory": "h",
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "@figma-forge/shared/*": ["../../packages/shared/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
